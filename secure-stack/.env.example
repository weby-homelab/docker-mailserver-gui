# --- DOMAIN CONFIGURATION ---
# The primary hostname of your mail server (e.g., mail.yourdomain.com)
MAIL_HOSTNAME=mail.example.com

# The hostname for your SnappyMail web interface (e.g., webmail.yourdomain.com)
WEBMAIL_HOSTNAME=webmail.example.com

# --- SECURITY & SSL ---
# Email address for Let's Encrypt notifications
ACME_EMAIL=admin@example.com

# --- SYSTEM ---
TZ=Europe/Kyiv
